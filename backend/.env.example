# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Get these from your Firebase project → Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
# Paste the private_key value from the JSON; keep the -----BEGIN PRIVATE KEY----- wrapping
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must be a verified domain/email in your Resend account
FROM_EMAIL=JURIS <reminders@yourdomain.com>

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── App URLs ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
