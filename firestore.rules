rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────
    // A user can only read/write their own profile document.
    match /users/{uid} {
      function isSignedIn() { return request.auth != null; }
      // Users can read their profile. Writes must be authenticated and
      // must not change the `role` field or other server-only metadata.
      allow read: if isSignedIn() && request.auth.uid == uid;

      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.keys().hasAll(['displayName'])
                    && !(request.resource.data.keys().hasAny(['role', 'isAdmin']));

      allow update: if isSignedIn() && request.auth.uid == uid
                    && !(request.resource.data.keys().hasAny(['role', 'isAdmin']))
                    && request.resource.data.size() <= 50;
      allow delete: if false; // deletes should be handled server-side
    }

    // ── Businesses ─────────────────────────────────────────────────────────
    // A business document and its tasks subcollection are only accessible
    // to the authenticated user whose UID matches ownerUid.
    match /businesses/{businessId} {
      function isSignedIn() { return request.auth != null; }
      // Owner can read; writes require owner verification. OwnerUid is immutable.
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;

      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.keys().hasAll(['name', 'ownerUid']);

      allow update: if isSignedIn()
                    && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerUid == request.auth.uid
                    && request.resource.data.ownerUid == resource.data.ownerUid // prevent owner change
                    && request.resource.data.name is string;

      // ── Tasks subcollection ──────────────────────────────────────────────
      match /tasks/{taskId} {
        allow read: if isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerUid;

        // Writes limited to specific fields and must be by owner
        allow create: if isSignedIn()
                      && request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerUid
                      && request.resource.data.keys().hasOnly(['label','description','dueDate','completed'])
                      && request.resource.data.label is string;

        allow update: if isSignedIn()
                      && request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerUid
                      && request.resource.data.keys().hasOnly(['label','description','dueDate','completed']);
      }
    }

    // ── Deny all others by default ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
